# .env.example - Environment Variables Template
# Copy this to .env and fill in your values

# GitHub Copilot SDK Configuration
# The SDK uses GitHub CLI authentication by default (gh auth login)
# If you need custom configuration, add these variables:

# GITHUB_TOKEN=your_github_token_here  # Optional: override GitHub CLI auth
# COPILOT_MODEL=gpt-4  # Optional: specify model (default uses Copilot's default)

# Database Configuration
# DATABASE_URL=sqlite:///./properties.db  # SQLite database path

# Server Configuration
# HOST=0.0.0.0
# PORT=8000
# RELOAD=True  # Auto-reload on code changes (development only)

# Logging
# LOG_LEVEL=info  # debug, info, warning, error, critical
